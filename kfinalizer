#!/usr/bin/env bash

# kfinalizer - Remove finalizers from Kubernetes resources
# Author: Claude
# Version: 1.0.0

# Don't exit on errors - we want to continue processing all resources
set +e

VERSION="1.0.0"
NAMESPACE=""
DRY_RUN=false
VERBOSE=false
FORCE_DELETE_NS=false
ALL_RESOURCES=false
SPECIFIC_RESOURCES=()

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Functions
print_usage() {
    cat << EOF
kfinalizer - Remove finalizers from Kubernetes resources

USAGE:
    kfinalizer [OPTIONS]

OPTIONS:
    -n, --namespace <name>      Namespace to clean (required)
    -r, --resource <type>       Specific resource type (can be used multiple times)
    -d, --dry-run              Show what would be done without making changes
    -f, --force                Force delete namespace after removing finalizers
    -v, --verbose              Show detailed output
    -h, --help                 Show this help message
    -V, --version              Show version

EXAMPLES:
    # Remove all finalizers from all resources in namespace
    kfinalizer -n opensearch

    # Dry run to see what would be removed
    kfinalizer -n nats --dry-run

    # Remove finalizers from specific resource types only
    kfinalizer -n opensearch -r opensearchclusters -r opensearchusers

    # Force delete namespace after cleaning
    kfinalizer -n opensearch --force

    # Verbose output with dry run
    kfinalizer -n my-namespace -v --dry-run

ENVIRONMENT VARIABLES:
    KFINALIZER_NAMESPACE    Default namespace if -n not specified
    KFINALIZER_DRY_RUN      Set to 'true' to enable dry-run mode

EOF
}

log_info() {
    echo -e "${BLUE}ℹ${NC} $1"
}

log_success() {
    echo -e "${GREEN}✓${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

log_error() {
    echo -e "${RED}✗${NC} $1" >&2
}

log_verbose() {
    if [ "$VERBOSE" = true ]; then
        echo -e "${NC}  $1"
    fi
}

check_prerequisites() {
    if ! command -v kubectl &> /dev/null; then
        log_error "kubectl is not installed or not in PATH"
        exit 1
    fi

    if ! kubectl cluster-info &> /dev/null; then
        log_error "Cannot connect to Kubernetes cluster"
        exit 1
    fi

    if [ -z "$NAMESPACE" ]; then
        log_error "Namespace is required. Use -n/--namespace or set KFINALIZER_NAMESPACE"
        echo ""
        print_usage
        exit 1
    fi

    if ! kubectl get namespace "$NAMESPACE" &> /dev/null; then
        log_error "Namespace '$NAMESPACE' does not exist"
        exit 1
    fi
}

get_resources_to_clean() {
    if [ ${#SPECIFIC_RESOURCES[@]} -gt 0 ]; then
        # Use specific resources provided by user
        printf '%s\n' "${SPECIFIC_RESOURCES[@]}"
    elif [ "$ALL_RESOURCES" = true ]; then
        # Get ALL namespaced resources (CRDs + built-in)
        kubectl api-resources --verbs=list --namespaced -o name 2>/dev/null
    else
        # Get only stuck resources from namespace conditions (DEFAULT)
        local stuck=$(kubectl get namespace "$NAMESPACE" -o jsonpath='{.status.conditions[?(@.type=="NamespaceContentRemaining")].message}' 2>/dev/null | \
            grep -oP '\S+\.\S+ has \d+' | awk '{print $1}' | sort -u 2>/dev/null)
        
        if [ -n "$stuck" ]; then
            echo "$stuck"
        else
            # Namespace not terminating or no stuck resources - fallback to all CRDs
            kubectl api-resources --verbs=list --namespaced -o name 2>/dev/null | grep '\.'
        fi
    fi
}

remove_finalizers() {
    local resource=$1
    local dry_run_flag=""
    
    if [ "$DRY_RUN" = true ]; then
        dry_run_flag="--dry-run=client"
    fi

    log_verbose "Checking resource: $resource"

    # Check if resource exists in namespace (don't exit on error)
    local check_result
    check_result=$(kubectl get "$resource" -n "$NAMESPACE" 2>&1) || {
        log_verbose "Resource type '$resource' not accessible: $check_result"
        return 0
    }

    local count=$(kubectl get "$resource" -n "$NAMESPACE" --no-headers 2>/dev/null | wc -l)
    
    if [ "$count" -eq 0 ]; then
        log_verbose "No instances of '$resource' found"
        return 0
    fi

    log_info "Processing $count instance(s) of $resource"

    # Try batch patch first
    if kubectl patch "$resource" --all -n "$NAMESPACE" $dry_run_flag \
        -p '{"metadata":{"finalizers":null}}' --type=merge &>/dev/null; then
        log_success "Removed finalizers from all $resource"
        return 0
    fi

    # Fallback: patch individually
    local success=0
    local failed=0
    local names=()
    
    while IFS= read -r res; do
        names+=("$res")
    done < <(kubectl get "$resource" -n "$NAMESPACE" -o name 2>/dev/null)
    
    for res in "${names[@]}"; do
        if kubectl patch "$res" -n "$NAMESPACE" $dry_run_flag \
            -p '{"metadata":{"finalizers":null}}' --type=merge 2>/dev/null; then
            log_verbose "Patched $res"
            ((success++))
        else
            log_warning "Failed to patch $res"
            ((failed++))
        fi
    done

    if [ ${#names[@]} -eq 0 ]; then
        log_verbose "No resources to patch"
    elif [ $failed -eq 0 ]; then
        log_success "Removed finalizers from all $resource ($success patched)"
    else
        log_warning "Removed finalizers from $resource ($success succeeded, $failed failed)"
    fi
}

force_delete_namespace() {
    if [ "$DRY_RUN" = true ]; then
        log_info "Would force delete namespace '$NAMESPACE'"
        return 0
    fi

    log_info "Force deleting namespace '$NAMESPACE'..."
    
    if kubectl get namespace "$NAMESPACE" -o json 2>/dev/null | \
        jq '.spec.finalizers = []' | \
        kubectl replace --raw "/api/v1/namespaces/$NAMESPACE/finalize" -f - &>/dev/null; then
        log_success "Namespace force deleted"
    else
        log_error "Failed to force delete namespace"
        exit 1
    fi
}

main() {
    # Check for environment variables
    NAMESPACE="${KFINALIZER_NAMESPACE:-}"
    [ "${KFINALIZER_DRY_RUN:-false}" = "true" ] && DRY_RUN=true

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -n|--namespace)
                NAMESPACE="$2"
                shift 2
                ;;
            -r|--resource)
                SPECIFIC_RESOURCES+=("$2")
                shift 2
                ;;
            -d|--dry-run)
                DRY_RUN=true
                shift
                ;;
            -a|--all)
                ALL_RESOURCES=true
                shift
                ;;
            -f|--force)
                FORCE_DELETE_NS=true
                shift
                ;;
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            -h|--help)
                print_usage
                exit 0
                ;;
            -V|--version)
                echo "kfinalizer version $VERSION"
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                echo ""
                print_usage
                exit 1
                ;;
        esac
    done

    # Check prerequisites
    check_prerequisites

    # Display mode
    if [ "$DRY_RUN" = true ]; then
        log_warning "DRY RUN MODE - No changes will be made"
    fi

    echo ""
    log_info "Namespace: $NAMESPACE"
    
    # Check namespace status and show what's stuck
    local ns_status=$(kubectl get namespace "$NAMESPACE" -o jsonpath='{.status.phase}' 2>/dev/null)
    if [ "$ns_status" = "Terminating" ]; then
        log_warning "Namespace is Terminating - checking what's stuck..."
        
        # Extract stuck resources from namespace conditions
        local stuck_resources=$(kubectl get namespace "$NAMESPACE" -o jsonpath='{.status.conditions[?(@.type=="NamespaceContentRemaining")].message}' 2>/dev/null | \
            grep -oP '\S+\.\S+ has \d+ resource' 2>/dev/null || true)
        
        if [ -n "$stuck_resources" ]; then
            log_info "Stuck resources found:"
            echo "$stuck_resources" | while read line; do
                echo "  - $line"
            done
        fi
        
        # Extract remaining finalizers
        local finalizers=$(kubectl get namespace "$NAMESPACE" -o jsonpath='{.status.conditions[?(@.type=="NamespaceFinalizersRemaining")].message}' 2>/dev/null | \
            grep -oP 'finalizers remaining: \K.*' 2>/dev/null || true)
        
        if [ -n "$finalizers" ]; then
            log_info "Finalizers: $finalizers"
        fi
        echo ""
    fi
    
    if [ ${#SPECIFIC_RESOURCES[@]} -gt 0 ]; then
        log_info "Target resources: ${SPECIFIC_RESOURCES[*]}"
    elif [ "$ALL_RESOURCES" = true ]; then
        log_info "Target: ALL namespaced resources"
    else
        log_info "Target: Stuck resources from namespace status"
    fi
    
    echo ""
    log_info "Removing finalizers..."
    echo ""

    # Process resources
    local resources=()
    while IFS= read -r resource; do
        resources+=("$resource")
    done < <(get_resources_to_clean)

    local total=${#resources[@]}
    log_verbose "Found $total resource types to check"
    
    local processed=0
    
    for resource in "${resources[@]}"; do
        remove_finalizers "$resource"
        ((processed++))
    done

    echo ""
    if [ $processed -gt 0 ]; then
        log_success "Processed $processed resource type(s)"
    else
        log_warning "No resources found to process"
    fi

    # Check namespace status
    if kubectl get namespace "$NAMESPACE" &>/dev/null; then
        local status=$(kubectl get namespace "$NAMESPACE" -o jsonpath='{.status.phase}' 2>/dev/null)
        
        if [ "$status" = "Terminating" ]; then
            log_warning "Namespace is still in Terminating state"
            
            if [ "$FORCE_DELETE_NS" = true ]; then
                echo ""
                force_delete_namespace
            else
                echo ""
                log_info "Use --force flag to force delete the namespace"
            fi
        else
            log_info "Namespace status: $status"
        fi
    else
        log_success "Namespace has been deleted"
    fi
}

# Run main function
main "$@"
